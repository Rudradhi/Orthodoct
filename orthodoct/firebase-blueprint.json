{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the OrthoDoct application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The URL of the user's profile picture." },
        "phoneNumber": { "type": "string", "description": "The user's phone number." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in." },
        "role": { "type": "string", "enum": ["patient", "admin"], "description": "The user's role in the system." }
      },
      "required": ["uid", "role"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "An AI analysis of a patient's orthopedic issue.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the analysis." },
        "uid": { "type": "string", "description": "The user ID who requested the analysis." },
        "issue": { "type": "string", "description": "The description of the discomfort provided by the user." },
        "result": { "type": "string", "description": "The AI-generated analysis result." },
        "mediaUrls": { 
          "type": "array", 
          "items": { "type": "string", "format": "uri" },
          "description": "List of URLs for images or media uploaded by the patient." 
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the analysis was performed." }
      },
      "required": ["uid", "issue", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "AI analysis records."
    }
  }
}
